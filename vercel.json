{
  "rewrites": [
    {
      "source": "/cors-proxy/(.*)",
      "destination": "/api/proxy?url=$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "fullscreen=(self *), autoplay=(self *)"
        }
      ]
    }
  ]
}
